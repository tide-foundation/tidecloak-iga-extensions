<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- 1: Create IGA_SERVER_CERT_DRAFT table -->
    <changeSet id="iga-1.5.0-1" author="tidecloak-iga">
        <createTable tableName="IGA_SERVER_CERT_DRAFT">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CHANGE_REQUEST_ID" type="VARCHAR(36)"/>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CLIENT_ID" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="INSTANCE_ID" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="SPIFFE_ID" type="VARCHAR(512)"/>
            <column name="PUBLIC_KEY" type="clob">
                <constraints nullable="false"/>
            </column>
            <column name="PUBLIC_KEY_FINGERPRINT" type="VARCHAR(255)"/>
            <column name="REQUESTED_LIFETIME" type="BIGINT"/>
            <column name="CERTIFICATE" type="clob"/>
            <column name="TRUST_BUNDLE" type="clob"/>
            <column name="SIGNED_POLICY" type="clob"/>
            <column name="REVOKED" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="REVOKED_AT" type="BIGINT"/>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- 2: Foreign key from IGA_SERVER_CERT_DRAFT.CHANGE_REQUEST_ID to IGA_CHANGE_REQUEST.ID -->
    <changeSet id="iga-1.5.0-2" author="tidecloak-iga">
        <addForeignKeyConstraint constraintName="FK_IGA_SERVER_CERT_CR"
                                 baseTableName="IGA_SERVER_CERT_DRAFT"
                                 baseColumnNames="CHANGE_REQUEST_ID"
                                 referencedTableName="IGA_CHANGE_REQUEST"
                                 referencedColumnNames="ID"
                                 onDelete="SET NULL"/>
    </changeSet>

    <!-- 3: Index on REALM_ID for the common per-realm lookup -->
    <changeSet id="iga-1.5.0-3" author="tidecloak-iga">
        <createIndex tableName="IGA_SERVER_CERT_DRAFT" indexName="IDX_IGA_SERVER_CERT_REALM">
            <column name="REALM_ID"/>
        </createIndex>
    </changeSet>

    <!-- 4: Composite index on (REALM_ID, INSTANCE_ID) for per-instance lookup -->
    <changeSet id="iga-1.5.0-4" author="tidecloak-iga">
        <createIndex tableName="IGA_SERVER_CERT_DRAFT" indexName="IDX_IGA_SERVER_CERT_REALM_INSTANCE">
            <column name="REALM_ID"/>
            <column name="INSTANCE_ID"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
