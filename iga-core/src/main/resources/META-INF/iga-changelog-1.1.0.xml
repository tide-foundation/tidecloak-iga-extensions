<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- 1: Create IGA_COMMENT table -->
    <changeSet id="iga-1.1.0-1" author="tidecloak-iga">
        <createTable tableName="IGA_COMMENT">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CHANGE_REQUEST_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK_IGA_COMMENT_CR"
                             references="IGA_CHANGE_REQUEST(ID)"/>
            </column>
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR(255)"/>
            <column name="COMMENT_TEXT" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
