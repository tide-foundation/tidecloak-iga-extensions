<?xml version="1.0" encoding="UTF-8"?>
<!--
  Marks this provider jar as a CDI bean archive so Quarkus folds its classes
  into the combined Jandex index. Quarkus REST (RESTEasy Reactive) discovers
  JAX-RS @Provider filters (ContainerRequestFilter / ContainerResponseFilter)
  by scanning that index in ResteasyReactiveScanningProcessor#scanForInterceptors
  (CombinedIndexBuildItem) — this is what makes IgaRepresentationCaptureFilter
  actually get registered. Without this marker file the jar is not an
  application archive, its classes are never indexed, and the @Provider filter
  is silently never invoked (the observed "filter not invoked / REP_JSON
  MISSING" symptom).

  bean-discovery-mode="annotated" (NOT the empty / "all" form) is deliberate:
  the file's mere presence is what marks the archive for Jandex indexing, so
  the filter is discovered regardless of discovery mode. "annotated" then
  restricts Arc/CDI bean *management* to classes carrying a bean-defining
  annotation. iga-core has none of those except @Path on the two admin
  resources, which are already @Vetoed. This avoids the prior
  "Unsatisfied dependency for type RealmModel" cascade that an empty/"all"
  beans.xml caused by trying to manage the Keycloak-SPI classes
  (IgaRealmProvider, adapters, services, entities, …) as CDI beans — those
  are instantiated by Keycloak's SPI with (KeycloakSession) constructors,
  not by CDI. The capture filter itself uses
  Resteasy.getContextData(KeycloakSession.class), not @Inject, so it needs
  no CDI injection and works purely as an index-discovered JAX-RS provider.
-->
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="annotated">
</beans>
