    <!--
      2.2.0: Drop OLD tide-jpa-providers schema.

      These tables are no longer used by tidecloak-iga-extensions; this migration
      cleans up deployments upgrading from the predecessor codebase. Each
      changeSet is guarded by a tableExists precondition (onFail=MARK_RAN) so the
      file is safe on fresh installs that never had the OLD schema, and equally
      safe on partial deployments where only some tables exist.

      No data migration is performed: the OLD schema is treated as dead. Tables
      are dropped child-before-parent (Group A) even though cascadeConstraints
      is set, as a belt-and-braces measure against any database that ignores or
      restricts cascade. Group B covers three orphan @Table classes
      (KEYCLOAK_GROUP_DRAFT, SIGNATURE_ENTRY, CLIENT_SCOPE_CLIENT_DRAFT) that
      may exist in some deployments but never had a managed lifecycle.

      Author: tidecloak-iga
    -->

    <!-- Group A: OLD-created tables, child-before-parent -->

    <!-- 1: ADMIN_AUTHORIZATIONS (FKs into CHANGESET_REQUEST) -->
    <changeSet id="iga-2.2.0-1" author="tidecloak-iga">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="ADMIN_AUTHORIZATIONS"/>
        </preConditions>
        <dropTable tableName="ADMIN_AUTHORIZATIONS" cascadeConstraints="true"/>
    </changeSet>

