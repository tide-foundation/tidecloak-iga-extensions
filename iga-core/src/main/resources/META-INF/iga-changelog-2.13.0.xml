<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- 1: Create IGA_SERVER_CERT_ENROLLMENT_TOKEN table (one-time server-cert enrollment tokens) -->
    <changeSet id="iga-2.13.0-1" author="tidecloak-iga">
        <createTable tableName="IGA_SERVER_CERT_ENROLLMENT_TOKEN">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CLIENT_ID" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="TOKEN_HASH" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="EXPIRES_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="CONSUMED_AT" type="BIGINT"/>
            <column name="CREATED_BY" type="VARCHAR(36)"/>
        </createTable>

        <createIndex tableName="IGA_SERVER_CERT_ENROLLMENT_TOKEN"
                     indexName="UX_IGA_SCET_REALM_HASH" unique="true">
            <column name="REALM_ID"/>
            <column name="TOKEN_HASH"/>
        </createIndex>

        <createIndex tableName="IGA_SERVER_CERT_ENROLLMENT_TOKEN"
                     indexName="IDX_IGA_SCET_REALM_CLIENT">
            <column name="REALM_ID"/>
            <column name="CLIENT_ID"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
