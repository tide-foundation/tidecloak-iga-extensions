<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!--
      1.9.0: Rename the SIGNATURE column to ATTESTATION on every IGA-tracked
      table. This aligns the column name with the new "attestation" naming
      across iga-core (signers package -> attestors package, IgaSigner ->
      IgaAttestor, etc.). The 11 entity tables from the original migrations
      and the 8 attribute tables added in 1.8.0 are all renamed.

      Author: tidecloak-iga
    -->

    <!-- ===== 11 entity tables (added in earlier migrations) ===== -->

    <!-- 1: USER_ENTITY.SIGNATURE -> ATTESTATION -->
    <changeSet id="iga-1.9.0-1" author="tidecloak-iga">
        <renameColumn tableName="USER_ENTITY"
                      oldColumnName="SIGNATURE"
                      newColumnName="ATTESTATION"
                      columnDataType="VARCHAR(2048)"/>
    </changeSet>

