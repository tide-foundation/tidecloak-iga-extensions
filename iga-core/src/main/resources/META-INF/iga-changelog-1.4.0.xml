<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- 1: Create IGA_FORSETI_CONTRACT table -->
    <changeSet id="iga-1.4.0-1" author="tidecloak-iga">
        <createTable tableName="IGA_FORSETI_CONTRACT">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CONTRACT_HASH" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="CONTRACT_CODE" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- 2: Unique constraint on (REALM_ID, CONTRACT_HASH) -->
    <changeSet id="iga-1.4.0-2" author="tidecloak-iga">
        <addUniqueConstraint tableName="IGA_FORSETI_CONTRACT"
                             columnNames="REALM_ID, CONTRACT_HASH"
                             constraintName="UQ_IGA_FORSETI_CONTRACT_REALM_HASH"/>
    </changeSet>

    <!-- 3: Index on REALM_ID for the common per-realm lookup -->
    <changeSet id="iga-1.4.0-3" author="tidecloak-iga">
        <createIndex tableName="IGA_FORSETI_CONTRACT" indexName="IDX_IGA_FORSETI_CONTRACT_REALM">
            <column name="REALM_ID"/>
        </createIndex>
    </changeSet>

    <!-- 4: Foreign key from IGA_ROLE_POLICY.CONTRACT_ID to IGA_FORSETI_CONTRACT.ID -->
    <changeSet id="iga-1.4.0-4" author="tidecloak-iga">
        <addForeignKeyConstraint constraintName="FK_IGA_ROLE_POLICY_CONTRACT"
                                 baseTableName="IGA_ROLE_POLICY"
                                 baseColumnNames="CONTRACT_ID"
                                 referencedTableName="IGA_FORSETI_CONTRACT"
                                 referencedColumnNames="ID"
                                 onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>
