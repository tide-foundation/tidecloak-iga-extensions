<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">

    <changeSet id="20260316-create-keycloak-group-draft" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="KEYCLOAK_GROUP_DRAFT"/></not>
        </preConditions>
        <createTable tableName="KEYCLOAK_GROUP_DRAFT">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CHANGE_REQUEST_ID" type="VARCHAR(36)"/>
            <column name="NAME" type="NVARCHAR(255)"/>
            <column name="PARENT_GROUP" type="VARCHAR(255)"/>
            <column name="REALM_ID" type="VARCHAR(255)"/>
            <column name="DRAFT_STATUS" type="VARCHAR(255)"/>
            <column name="ACTION_TYPE" type="VARCHAR(255)"/>
            <column name="CREATED_TIMESTAMP" type="BIGINT"/>
        </createTable>
        <addUniqueConstraint tableName="KEYCLOAK_GROUP_DRAFT"
                             columnNames="REALM_ID, PARENT_GROUP, NAME"
                             constraintName="UK_GROUP_DRAFT_REALM_PARENT_NAME"/>
    </changeSet>

</databaseChangeLog>
