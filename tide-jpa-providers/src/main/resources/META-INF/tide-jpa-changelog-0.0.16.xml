<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">

    <!-- Add requestedBy columns to CHANGESET_REQUEST -->
    <changeSet id="20260315-add-requested-by-to-changeset-request" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="CHANGESET_REQUEST" columnName="REQUESTED_BY"/></not>
        </preConditions>
        <addColumn tableName="CHANGESET_REQUEST">
            <column name="REQUESTED_BY" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="REQUESTED_BY_USERNAME" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add timestamp and username to ADMIN_AUTHORIZATIONS -->
    <changeSet id="20260315-add-timestamp-username-to-admin-authorizations" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="ADMIN_AUTHORIZATIONS" columnName="ACTION_TIMESTAMP"/></not>
        </preConditions>
        <addColumn tableName="ADMIN_AUTHORIZATIONS">
            <column name="ACTION_TIMESTAMP" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="USERNAME" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Create CHANGESET_COMMENTS table -->
    <changeSet id="20260315-create-changeset-comments" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="CHANGESET_COMMENTS"/></not>
        </preConditions>
        <createTable tableName="CHANGESET_COMMENTS">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CHANGESET_REQUEST_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CHANGE_SET_TYPE" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="COMMENT" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="TIMESTAMP" type="BIGINT"/>
        </createTable>
        <addPrimaryKey columnNames="ID" constraintName="PK_CHANGESET_COMMENTS" tableName="CHANGESET_COMMENTS"/>
    </changeSet>

</databaseChangeLog>
