<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">

    <!-- Add DELETE_STATUS column to CLIENT_DRAFT for client deletion drafting -->
    <changeSet id="20260315-add-delete-status-to-client-draft" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="CLIENT_DRAFT" columnName="DELETE_STATUS"/></not>
        </preConditions>
        <addColumn tableName="CLIENT_DRAFT">
            <column name="DELETE_STATUS" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
