<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">

    <!-- Add WALLET_ID column to LICENSE_HISTORY -->
    <changeSet id="20260402-add-wallet-id-to-license-history" author="tidecloak">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="LICENSE_HISTORY" columnName="WALLET_ID"/>
            </not>
        </preConditions>

        <addColumn tableName="LICENSE_HISTORY">
            <column name="WALLET_ID" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="LICENSE_HISTORY" columnName="WALLET_ID"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
